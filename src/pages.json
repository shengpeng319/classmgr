{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "小孩课程管理",
        "navigationBarBackgroundColor": "#87CEEB",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/today/today",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/history/history",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/schedule/schedule",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/lottery/lottery",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/points/points",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/user/user",
      "style": {
        "navigationBarTitleText": "用户管理",
        "navigationBarBackgroundColor": "#87CEEB",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/profile/profile",
      "style": {
        "navigationBarTitleText": "个人资料",
        "navigationBarBackgroundColor": "#87CEEB",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "小孩课程管理",
    "navigationBarBackgroundColor": "#87CEEB",
    "backgroundColor": "#F0F8FF"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#87CEEB",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/today/today",
        "text": "今日任务",
        "iconPath": "static/tabs/today.png",
        "selectedIconPath": "static/tabs/today-active.png"
      },
      {
        "pagePath": "pages/history/history",
        "text": "历史任务",
        "iconPath": "static/tabs/history.png",
        "selectedIconPath": "static/tabs/history-active.png"
      },
      {
        "pagePath": "pages/schedule/schedule",
        "text": "课程表",
        "iconPath": "static/tabs/schedule.png",
        "selectedIconPath": "static/tabs/schedule-active.png"
      },
      {
        "pagePath": "pages/points/points",
        "text": "积分",
        "iconPath": "static/tabs/points.png",
        "selectedIconPath": "static/tabs/points-active.png"
      }
    ]
  },
  "uniIdRouter": {}
}
