generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("user")  // "admin" or "user"
  name      String?
  avatar    String?
  gender    String   @default("male")
  age       Int      @default(0)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rememberedUsers RememberedUser[]
  tasks     Task[]
  student   Student?
}

model RememberedUser {
  id           String   @id @default(uuid())
  userId       String
  deviceId     String
  rememberToken String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  
  @@unique([userId, deviceId])
}

model Student {
  id        String   @id @default(uuid())
  name      String
  avatar    String?
  points    Int      @default(0)
  userId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courses   CourseStudent[]
  records   Record[]
  ownedCards StudentCard[]
  user      User?    @relation(fields: [userId], references: [id])
}

model Course {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?  @default("#87CEEB")
  dayOfWeek   Int      // 0-6, 0=Sunday
  startTime   String   // "09:00"
  endTime     String   // "10:00"
  location    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  students    CourseStudent[]
}

model CourseStudent {
  id        String   @id @default(uuid())
  studentId String
  courseId  String
  student   Student  @relation(fields: [studentId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  @@unique([studentId, courseId])
}

model Record {
  id          String   @id @default(uuid())
  studentId   String
  courseId    String
  date        DateTime
  status      String   // "attended", "absent", "late"
  note        String?
  pointsEarned Int     @default(0)
  createdAt   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id])
}

model Card {
  id          String   @id @default(uuid())
  name        String
  description String?
  rarity      String   // "common", "rare", "epic", "legendary"
  image       String?
  pointsCost  Int      @default(10)
  stock       Int      @default(-1)  // -1 = unlimited
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owners      StudentCard[]
}

model StudentCard {
  id        String   @id @default(uuid())
  studentId String
  cardId    String
  drawnAt   DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
  card      Card     @relation(fields: [cardId], references: [id])

  @@unique([studentId, cardId])
}

model Task {
  id          String    @id @default(uuid())
  title       String
  type        String    // "homework" | "extracurricular"
  points      Int       @default(5)  // 任务积分
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  userId      String    // 关联用户
  startDate   DateTime  // 有效开始日期
  endDate     DateTime  // 有效结束日期
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
}
