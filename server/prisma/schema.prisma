generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("user")  // "admin" or "user"
  name      String?
  avatar    String?
  gender    String   @default("male")
  age       Int      @default(0)
  phone     String?
  points    Int      @default(0)  // 积分（用于抽卡）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rememberedUsers RememberedUser[]
  tasks     Task[]
  schedules Schedule[]
  courseStudents CourseStudent[]
  records   Record[]
  ownedCards StudentCard[]
  pointRecords PointRecord[]
}

model RememberedUser {
  id           String   @id @default(uuid())
  userId       String
  deviceId     String
  rememberToken String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  
  @@unique([userId, deviceId])
}

model Course {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String?  @default("#87CEEB")
  dayOfWeek   Int      // 0-6, 0=Sunday
  startTime   String   // "09:00"
  endTime     String   // "10:00"
  location    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  students    CourseStudent[]
}

model CourseStudent {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model Record {
  id          String   @id @default(uuid())
  userId      String
  courseId    String
  date        DateTime
  status      String   // "attended", "absent", "late"
  note        String?
  pointsEarned Int     @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Card {
  id          String   @id @default(uuid())
  name        String
  description String?
  rarity      String   // "common", "rare", "epic", "legendary"
  image       String?
  pointsCost  Int      @default(10)
  stock       Int      @default(-1)  // -1 = unlimited
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owners      StudentCard[]
}

model StudentCard {
  id        String   @id @default(uuid())
  userId    String
  cardId    String
  drawnAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  card      Card     @relation(fields: [cardId], references: [id])

  @@unique([userId, cardId])
}

model Task {
  id          String    @id @default(uuid())
  title       String
  type        String    // "school" | "tutoring" | "homework" | "sports" | "art" | "other"
  points      Int       @default(5)  // 任务积分
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  userId      String    // 关联用户
  startDate   DateTime  // 有效开始日期
  endDate     DateTime  // 有效结束日期
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
}

model Schedule {
  id          String    @id @default(uuid())
  name        String    // 课程名称
  dayOfWeek   String    // "1,3" 逗号分隔的星期几，0=周日
  startTime   String    // "09:00"
  endTime     String    // "10:00"
  location    String?   // 上课地点
  type        String    // "school" | "tutoring" | "homework" | "sports" | "art" | "other"
  color       String?   @default("#87CEEB")  // 颜色标记
  isDailyTask Boolean   @default(false)  // 是否为当日任务
  points      Int       @default(1)  // 任务积分
  userId      String    // 关联用户
  startDate   DateTime? // 有效期起始（为空表示从过去任何时间开始）
  endDate     DateTime? // 有效期结束（为空表示永久有效）
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
}

model PointRecord {
  id          String   @id @default(uuid())
  userId      String
  taskId      String?  // 关联任务ID
  taskTitle   String   // 任务标题（冗余存储，方便显示）
  points      Int      // 积分变化（正数表示获得，负数表示扣除）
  reason      String   // 原因： "完成任务" | "取消完成"
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}